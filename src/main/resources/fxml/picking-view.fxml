<?xml version="1.0" encoding="UTF-8"?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.chrisb97.warehouse.controller.PickingController" spacing="12" styleClass="page"><Label text="Picking Route" styleClass="page-title"/><HBox spacing="8"><ComboBox fx:id="productCombo" promptText="Product" prefWidth="360"/><TextField fx:id="quantityField" promptText="Quantity" prefWidth="110"/><Button text="Add / Replace" onAction="#addItem" styleClass="primary-button"/><Button text="Remove" onAction="#removeItem"/><CheckBox fx:id="returnCheck" text="Return to entrance" selected="true"/></HBox><SplitPane VBox.vgrow="ALWAYS"><VBox spacing="8"><Label text="Picking list" styleClass="section-title"/><TableView fx:id="requestTable" VBox.vgrow="ALWAYS"><columns><TableColumn fx:id="requestProductColumn" text="Product" prefWidth="280"/><TableColumn fx:id="requestQuantityColumn" text="Requested" prefWidth="90"/><TableColumn fx:id="requestLocationColumn" text="Location" prefWidth="90"/></columns></TableView></VBox><VBox spacing="8"><Label text="Optimised visit order" styleClass="section-title"/><ListView fx:id="routeList" VBox.vgrow="ALWAYS"/><HBox><Label text="Estimated Manhattan distance: "/><Label fx:id="distanceLabel" text="0 units" styleClass="section-title"/></HBox></VBox></SplitPane><HBox spacing="8"><Button text="Generate route" onAction="#generate" styleClass="primary-button"/><Button text="Clear" onAction="#clear"/></HBox><Label text="The route uses a nearest-neighbour heuristic. Products at the same location are grouped into one stop." wrapText="true" styleClass="hint"/></VBox>
