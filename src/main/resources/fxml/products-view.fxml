<?xml version="1.0" encoding="UTF-8"?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.chrisb97.warehouse.controller.ProductsController" spacing="12" styleClass="page"><Label text="Products" styleClass="page-title"/><HBox spacing="10"><TextField fx:id="searchField" promptText="Search name, SKU or location" HBox.hgrow="ALWAYS"/><ComboBox fx:id="categoryFilter" promptText="Category"/><CheckBox fx:id="lowStockOnly" text="Low stock only"/></HBox><SplitPane VBox.vgrow="ALWAYS" dividerPositions="0.68"><TableView fx:id="table"><columns><TableColumn fx:id="skuColumn" text="SKU" prefWidth="110"/><TableColumn fx:id="nameColumn" text="Name" prefWidth="190"/><TableColumn fx:id="categoryColumn" text="Category" prefWidth="110"/><TableColumn fx:id="quantityColumn" text="Qty" prefWidth="60"/><TableColumn fx:id="minimumColumn" text="Min" prefWidth="60"/><TableColumn fx:id="locationColumn" text="Location" prefWidth="90"/><TableColumn fx:id="statusColumn" text="Stock" prefWidth="65"/><TableColumn fx:id="activeColumn" text="Status" prefWidth="80"/></columns><placeholder><Label text="No products match the filters."/></placeholder></TableView><VBox spacing="9" styleClass="form-panel"><Label text="Product details" styleClass="section-title"/><Label text="SKU"/><TextField fx:id="skuField"/><Label text="Name"/><TextField fx:id="nameField"/><Label text="Description"/><TextField fx:id="descriptionField"/><Label text="Category"/><TextField fx:id="categoryField"/><Label text="Minimum stock"/><TextField fx:id="minimumField"/><Label text="Location"/><ComboBox fx:id="locationCombo" maxWidth="Infinity"/><CheckBox fx:id="activeCheck" text="Active"/><HBox spacing="8"><Button text="New" onAction="#newProduct"/><Button text="Save" onAction="#save" styleClass="primary-button"/><Button text="Deactivate" onAction="#deactivate" styleClass="danger-button"/></HBox></VBox></SplitPane></VBox>
