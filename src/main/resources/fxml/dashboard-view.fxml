<?xml version="1.0" encoding="UTF-8"?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.chrisb97.warehouse.controller.DashboardController" spacing="18" styleClass="page">
 <Label text="Dashboard" styleClass="page-title"/><HBox spacing="14"><VBox styleClass="metric-card"><Label text="Active products"/><Label fx:id="productsLabel" styleClass="metric-value"/></VBox><VBox styleClass="metric-card"><Label text="Units in stock"/><Label fx:id="totalQuantityLabel" styleClass="metric-value"/></VBox><VBox styleClass="metric-card"><Label text="Active locations"/><Label fx:id="locationsLabel" styleClass="metric-value"/></VBox><VBox styleClass="metric-card warning"><Label text="Low stock"/><Label fx:id="lowStockLabel" styleClass="metric-value"/></VBox></HBox>
 <SplitPane VBox.vgrow="ALWAYS"><VBox spacing="8"><Label text="Latest stock movements" styleClass="section-title"/><TableView fx:id="movementsTable" VBox.vgrow="ALWAYS"><columns><TableColumn fx:id="dateColumn" text="Date" prefWidth="145"/><TableColumn fx:id="productColumn" text="Product" prefWidth="270"/><TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/><TableColumn fx:id="quantityColumn" text="Qty" prefWidth="70"/></columns><placeholder><Label text="No movement recorded yet."/></placeholder></TableView></VBox><VBox spacing="8"><Label text="Low-stock products" styleClass="section-title"/><ListView fx:id="lowStockList" VBox.vgrow="ALWAYS" prefWidth="340"><placeholder><Label text="No low-stock product."/></placeholder></ListView></VBox></SplitPane>
</VBox>
