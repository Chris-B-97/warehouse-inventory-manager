<?xml version="1.0" encoding="UTF-8"?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.chrisb97.warehouse.controller.StockController" spacing="15" styleClass="page"><Label text="Stock Operations" styleClass="page-title"/><GridPane hgap="12" vgap="10" styleClass="form-panel"><Label text="Product" GridPane.rowIndex="0"/><ComboBox fx:id="productCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0"/><Label text="Current stock" GridPane.columnIndex="2" GridPane.rowIndex="0"/><Label fx:id="currentStockLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="0"/><Label text="Current location" GridPane.columnIndex="2" GridPane.rowIndex="1"/><Label fx:id="currentLocationLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1"/><Label text="Quantity / new quantity" GridPane.rowIndex="2"/><TextField fx:id="quantityField" GridPane.columnIndex="1" GridPane.rowIndex="2"/><Label text="Location for stock in" GridPane.rowIndex="3"/><ComboBox fx:id="locationCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/><Label text="Target location for transfer" GridPane.rowIndex="4"/><ComboBox fx:id="targetLocationCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4"/><Label text="Reason" GridPane.rowIndex="5"/><TextField fx:id="reasonField" GridPane.columnIndex="1" GridPane.rowIndex="5"/><Label text="Reference (optional)" GridPane.rowIndex="6"/><TextField fx:id="referenceField" GridPane.columnIndex="1" GridPane.rowIndex="6"/><columnConstraints><ColumnConstraints minWidth="180"/><ColumnConstraints hgrow="ALWAYS" minWidth="260"/><ColumnConstraints minWidth="130"/><ColumnConstraints minWidth="120"/></columnConstraints></GridPane><HBox spacing="10"><Button text="Stock In" onAction="#stockIn" styleClass="primary-button"/><Button text="Stock Out" onAction="#stockOut"/><Button text="Adjust" onAction="#adjust"/><Button text="Transfer" onAction="#transfer"/></HBox><Label text="Each operation updates the product and writes its movement in one database transaction. A failure triggers a rollback." wrapText="true" styleClass="hint"/></VBox>
